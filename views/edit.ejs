<!DOCTYPE html>
<html lang="en">
<%- include('partials/head'); %>
<body>
    <%- include('partials/header'); %>
    <main>
        <div class="content-box" style="max-width: 600px; margin: 0 auto;">
            <h2>Edit Submission</h2>
            <p>Changes will be reviewed by a moderator before going live.</p>
            
            <form action="/edit/<%= submission.id %>" method="POST" enctype="multipart/form-data">
                
                <div class="form-group">
                    <label>Title</label>
                    <input type="text" name="title" value="<%= submission.title %>" required>
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <textarea name="description" rows="10" required><%= submission.description %></textarea>
                </div>

                <div class="form-group">
                    <label>Tags</label>
                    <input type="text" name="tags" value="<%= submission.tags || '' %>">
                </div>

                <div class="form-group" style="border-top: 1px solid #444; padding-top: 1rem; margin-top: 1rem;">
                    <label>New Thumbnail (Leave empty to keep current)</label>
                    <input type="file" name="thumbnailFile" accept="image/*">
                </div>

                <div class="form-group">
                    <label>New File (Leave empty to keep current)</label>
                    <input type="file" name="downloadFile">
                </div>

                <div style="margin-top: 2rem; display: flex; gap: 1rem;">
                    <button type="submit" class="button" style="flex: 1;">Submit Changes</button>
                    <a href="/submission/<%= submission.id %>" class="button" style="background: transparent; border: 1px solid #555; flex: 1; text-align: center;">Cancel</a>
                </div>
            </form>
        </div>
    </main>
    <%- include('partials/footer'); %>
</body>
</html>
