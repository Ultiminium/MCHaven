<!DOCTYPE html>
<html lang="en">
<%- include('partials/head'); %>
<body>
    <%- include('partials/header'); %>
    <main>
        <div class="content-box" style="max-width:500px; margin: 5rem auto; text-align:center; border: 2px solid <%= type === 'error' ? '#ff4444' : '#4CAF50' %>;">
            <h2 style="color: <%= type === 'error' ? '#ff4444' : '#4CAF50' %>;"><%= title %></h2>
            <p><%= message %></p>
            <div style="margin-top: 2rem;">
                <a href="/" class="button">Go Home</a>
                <a href="javascript:history.back()" class="button" style="background:transparent; border:1px solid #555;">Go Back</a>
            </div>
        </div>
    </main>
    <%- include('partials/footer'); %>
</body>
</html>
