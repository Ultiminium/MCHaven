<!DOCTYPE html>
<html lang="en">
<%- include('partials/head'); %>
<body>
    <%- include('partials/header'); %>
    <main>
        <% if (submission.status === 'rejected') { %>
            <div class="content-box" style="border: 2px solid #ff4444; background: rgba(255, 68, 68, 0.05); margin-bottom: 2rem;">
                <h3 style="color: #ff4444; margin-top: 0;">⚠️ Submission Rejected</h3>
                <p><strong>Reason:</strong> <%= submission.rejection_reason %></p>
                <p><strong>Advice:</strong> <%= submission.rejection_advice %></p>
                <form action="/submission/delete/<%= submission.id %>" method="POST" style="margin-top: 1rem;">
                    <button type="submit" class="button" style="background:#ff4444;">Delete Submission</button>
                </form>
            </div>
        <% } %>

        <% if (submission.status === 'pending') { %>
            <div class="content-box" style="border: 2px solid #ffbb33; background: rgba(255, 187, 51, 0.05); margin-bottom: 2rem;">
                <h3 style="color: #ffbb33; margin-top: 0;">⏳ Pending Review</h3>
                <p>This content is waiting for approval.</p>
            </div>
        <% } %>

        <div class="content-box">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; margin-bottom: 1rem;">
                <div style="max-width: 80%;">
                    <h1 style="margin: 0 0 0.5rem 0; word-wrap: break-word;"><%= submission.title %></h1>
                    <div class="card-meta-info">
                        <span class="category-tag"><%= submission.category %></span>
                        <span class="category-tag" style="background: <%= submission.edition === 'java' ? '#d32f2f' : '#388e3c' %>;"><%= submission.edition %></span>
                        <% if (submission.supported_versions) { %><span class="version-tag">v<%= submission.supported_versions %></span><% } %>
                    </div>
                </div>
                
                <% if (locals.userId === submission.user_id) { %>
                    <a href="/edit/<%= submission.id %>" class="button" style="background: var(--bg-primary); border: 1px solid var(--border-color);">✏️ Edit</a>
                <% } %>
            </div>

            <div class="gallery-container" style="margin-bottom: 2rem;">
                <img src="<%= submission.thumbnail_url %>" style="width: 100%; max-height: 400px; object-fit: cover; border-radius: 8px; border: 2px solid var(--border-color);">
                <% if (submission.image_url_1 || submission.image_url_2 || submission.image_url_3) { %>
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 10px; margin-top: 10px;">
                        <% [submission.image_url_1, submission.image_url_2, submission.image_url_3].forEach(img => { %>
                            <% if(img) { %><img src="<%= img %>" style="width:100%; height:80px; object-fit:cover; border-radius:5px; cursor:pointer;" onclick="window.open(this.src)"><% } %>
                        <% }); %>
                    </div>
                <% } %>
            </div>

            <% if (submission.description.length > 800) { %>
                <a href="#downloads" style="display: inline-block; margin-bottom: 1rem; font-weight: bold; color: var(--accent-primary); text-decoration: none; border: 1px solid var(--accent-primary); padding: 5px 10px; border-radius: 5px;">
                    ⬇ Skip to Download
                </a>
            <% } %>

            <div style="white-space: pre-wrap; line-height: 1.6; margin-bottom: 2rem; overflow-wrap: break-word; word-break: break-word; max-width: 100%;">
                <%= submission.description %>
            </div>

            <% if (submission.tags) { %>
                <div style="margin-bottom: 2rem; color: var(--text-secondary);">
                    <strong>Tags:</strong> 
                    <% submission.tags.split(',').forEach(tag => { %>
                        <span style="background: var(--bg-primary); padding: 2px 8px; border-radius: 4px; margin-right: 5px; font-size: 0.9rem;">#<%= tag.trim() %></span>
                    <% }); %>
                </div>
            <% } %>

            <div id="downloads" class="actions-section" style="border-top: 1px solid var(--border-color); padding-top: 1.5rem; display: flex; gap: 1rem; flex-wrap: wrap; align-items: center;">
                
                <% if (submission.status === 'approved' || locals.userId === submission.user_id || userRole === 'admin') { %>
                    <% if (submission.download_url.startsWith('/')) { %>
                        <a href="<%= submission.download_url %>" class="button" download>Download File</a>
                    <% } else { %>
                        <a href="/download-redirect?url=<%= encodeURIComponent(submission.download_url) %>" class="button" target="_blank">Download External</a>
                    <% } %>
                <% } else { %>
                    <button class="button" disabled style="background: #555; cursor: not-allowed;">Download Locked</button>
                <% } %>

                <a href="<%= submission.credit_url %>" target="_blank" style="color: var(--accent-primary);">Credits</a>

                <% if (locals.userId === submission.user_id || userRole === 'admin' || userRole === 'mod') { %>
                    <form action="/submission/delete/<%= submission.id %>" method="POST" onsubmit="return confirm('Delete this?');" style="margin-left: auto;">
                        <button type="submit" class="button" style="background: #ff4444;">Delete</button>
                    </form>
                <% } %>
            </div>
        </div>

        <div class="content-box" style="margin-top: 2rem;">
            <h3>Comments (<%= comments.length %>)</h3>
            <% if (locals.userId) { %>
                <form action="/submission/<%= submission.id %>/comment" method="POST" style="display:flex; gap:10px; margin-bottom:1rem;">
                    <input type="text" name="comment_text" required placeholder="Leave a comment..." style="flex:1;">
                    <button type="submit" class="button">Post</button>
                </form>
            <% } else { %> <p><a href="/login.html">Login</a> to comment.</p> <% } %>
            
            <% comments.forEach(c => { %>
                <div class="comment" style="border-top:1px solid var(--border-color); padding:10px 0; display:flex; gap:10px;">
                    <img src="<%= c.pfp_url %>" style="width:40px; height:40px; border-radius:50%;">
                    <div style="flex: 1; min-width: 0;">
                        <strong><a href="/profile/<%= c.username %>"><%= c.username %></a></strong>
                        <p style="margin:5px 0; overflow-wrap: break-word; word-break: break-word;"><%= c.comment_text %></p>
                        <div style="font-size:0.8rem;">
                            <% if (locals.userId) { %>
                                <form action="/comment/<%= c.id %>/report" method="POST" style="display:inline;"><button style="background:none; border:none; color:#777; cursor:pointer;">Report</button></form>
                            <% } %>
                            <% if (userRole === 'admin' || userRole === 'mod') { %>
                                <form action="/comment/<%= c.id %>/delete" method="POST" style="display:inline;"><button style="background:none; border:none; color:#ff4444; cursor:pointer;">Delete</button></form>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </main>
    <%- include('partials/footer'); %>
    <script src="/auth.js"></script>
</body>
</html>
