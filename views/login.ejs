<!DOCTYPE html>
<html lang="en">
<%- include('partials/head'); %>
<body>
    <%- include('partials/header'); %>
    <main>
        <div class="content-box" style="max-width: 400px; margin: 0 auto; text-align: center;">
            <h2>Login</h2>
            
            <% if (typeof message !== 'undefined' && message) { %>
                <div class="message success">
                    <p><%= message %></p>
                </div>
            <% } %>

            <script>
                const urlParams = new URLSearchParams(window.location.search);
                if (urlParams.get('success') === 'PasswordReset') {
                    document.write('<div class="message success"><p>Password reset successfully! Please log in.</p></div>');
                }
            </script>
            
            <form action="/login" method="POST">
                <div class="form-group">
                    <label style="text-align: left; display: block;">Username</label>
                    <input type="text" name="username" placeholder="Username" required>
                </div>

                <div class="form-group">
                    <label style="text-align: left; display: block;">Email</label>
                    <input type="email" name="email" placeholder="Email" required>
                </div>

                <div class="form-group">
                    <label style="text-align: left; display: block;">Password</label>
                    <input type="password" name="password" placeholder="Password" required>
                </div>
                
                <button type="submit" class="button" style="width: 100%;">Login</button>
            </form>

            <div style="margin-top: 1rem; font-size: 0.9rem;">
                <a href="/forgot-password" style="color: var(--accent-primary); text-decoration: none;">Forgot Password?</a>
            </div>

            <hr style="margin: 1.5rem 0; border: 0; border-top: 1px solid var(--border-color);">

            <p>Don't have an account? <a href="/register.html" style="color: var(--accent-primary);">Register</a></p>
        </div>
    </main>
    <%- include('partials/footer'); %>
    <script src="/auth.js"></script>
</body>
</html>
