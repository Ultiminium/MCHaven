<!DOCTYPE html>
<html lang="en">
<%- include('partials/head'); %>
<body>
    <%- include('partials/header'); %>
    <main>
        <div class="content-box">
            <h2>Admin Dashboard</h2>
            <p>Welcome, <%= username %>.</p>
        </div>

        <% if (pendingEdits.length > 0) { %>
            <h3 style="margin-top: 2rem; color: gold;">✏️ Pending Edits (<%= pendingEdits.length %>)</h3>
            <div class="item-container">
                <% pendingEdits.forEach(edit => { %>
                    <div class="item-card" style="border: 1px solid gold;">
                        <div class="info" style="padding: 1rem;">
                            <h4>Edit to: "<%= edit.original_title %>"</h4>
                            <p style="font-size:0.85rem;"><strong>Proposed Title:</strong> <%= edit.title %></p>
                            <p style="font-size:0.85rem;"><strong>Changed Desc:</strong> <%= edit.description.substring(0,50) %>...</p>
                            
                            <div style="margin-top:1rem; display:flex; gap:0.5rem;">
                                <form action="/admin/edit/approve/<%= edit.id %>" method="POST" style="flex:1;">
                                    <button class="button" style="background:#4CAF50; width:100%;">Merge Edit</button>
                                </form>
                                <form action="/admin/edit/reject/<%= edit.id %>" method="POST" style="flex:1;">
                                    <button class="button" style="background:#ff4444; width:100%;">Discard</button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>

        <h3>Pending New Content (<%= submissions.length %>)</h3>
        <div class="item-container">
            <% if (submissions.length > 0) { %>
                <% submissions.forEach(sub => { %>
                    <div class="item-card">
                        <img src="<%= sub.thumbnail_url %>" style="height:150px; width:100%; object-fit:cover;">
                        <div class="info">
                            <h4><%= sub.title %></h4>
                            <p>User #<%= sub.user_id %></p>
                            <a href="/submission/<%= sub.id %>" target="_blank">View Page</a>
                            <div style="margin-top:10px; display:flex; gap:5px;">
                                <form action="/admin/approve/<%= sub.id %>" method="POST"><button class="button" style="background:#4CAF50;">Approve</button></form>
                                <button class="button" style="background:#ff4444;" onclick="openRejectModal('<%= sub.id %>')">Reject</button>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %><p>No new submissions.</p><% } %>
        </div>

        <h3>Staff Team</h3>
        <div class="user-card-grid">
            <% staff.forEach(u => { %>
                <div class="user-result-card">
                    <img src="<%= u.pfp_url %>" class="user-result-img">
                    <p><strong><%= u.username %></strong> (<%= u.role %>)</p>
                    <% if (userRole === 'admin' && u.role === 'mod') { %>
                        <form action="/profile/<%= u.username %>/demote" method="POST" onsubmit="return confirm('Demote?');">
                            <button class="button" style="background:#ff4444; font-size:0.8rem; padding:5px 10px;">Demote</button>
                        </form>
                    <% } %>
                </div>
            <% }); %>
        </div>

        <h3>Reported Users</h3>
        <% reportedUsers.forEach(u => { %>
            <div class="content-box" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
                <div style="display:flex; align-items:center; gap:1rem;">
                    <img src="<%= u.pfp_url %>" style="width:40px; height:40px; border-radius:50%;">
                    <strong><%= u.username %></strong>
                </div>
                <div style="display:flex; gap:10px;">
                    <form action="/admin/user/<%= u.id %>/dismiss" method="POST"><button class="button">Dismiss</button></form>
                    <button class="button" style="background:darkred;" onclick="openTermModal('<%= u.id %>')">TERMINATE</button>
                </div>
            </div>
        <% }); %>

    </main>

    <dialog id="rejectDialog" style="border:1px solid #555; background:var(--bg-secondary); color:white; padding:20px; border-radius:8px;">
        <h3>Reject Submission</h3>
        <form id="rejectForm" method="POST">
            <select name="reason" required style="width:100%; margin-bottom:10px; padding:8px;">
                <option value="Low Quality">Low Quality</option>
                <option value="Stolen">Stolen</option>
                <option value="Broken">Broken</option>
            </select>
            <textarea name="advice" placeholder="Advice..." style="width:100%; margin-bottom:10px; padding:8px;"></textarea>
            <div style="display:flex; justify-content:flex-end; gap:10px;">
                <button type="button" onclick="document.getElementById('rejectDialog').close()">Cancel</button>
                <button type="submit" class="button" style="background:#ff4444;">Reject</button>
            </div>
        </form>
    </dialog>

    <dialog id="termDialog" style="border:2px solid red; background:#111; color:white; padding:20px; border-radius:8px;">
        <h3 style="color:red;">TERMINATE ACCOUNT</h3>
        <p>This action cannot be undone.</p>
        <form id="termForm" method="POST">
            <textarea name="reason" placeholder="Reason for ban..." required style="width:100%; margin-bottom:10px; padding:8px;"></textarea>
            <button type="submit" class="button" style="background:red; width:100%;">CONFIRM BAN</button>
        </form>
    </dialog>

    <script>
        function openRejectModal(id) { document.getElementById('rejectForm').action = `/admin/reject/${id}`; document.getElementById('rejectDialog').showModal(); }
        function openTermModal(id) { document.getElementById('termForm').action = `/admin/terminate/${id}`; document.getElementById('termDialog').showModal(); }
    </script>
    <%- include('partials/footer'); %>
    <script src="/auth.js"></script>
</body>
</html>
