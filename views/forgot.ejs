<!DOCTYPE html>
<html lang="en">
<%- include('partials/head'); %>
<body>
    <%- include('partials/header'); %>
    <main>
        <div class="content-box" style="max-width: 400px; margin: 0 auto; text-align: center;">
            <h2>Forgot Password</h2>
            <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">
                For security, please verify your account details.
            </p>
            
            <% if (message) { %>
                <div class="message" style="background-color: #333; border: 1px solid var(--accent-primary); padding: 10px; border-radius: 5px; margin-bottom: 1rem;">
                    <%= message %>
                </div>
            <% } %>

            <form action="/forgot-password" method="POST" style="text-align: left;">
                
                <div class="form-group">
                    <label>Username</label>
                    <input type="text" name="username" placeholder="Your username" required>
                </div>

                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" name="email" placeholder="address@example.com" required>
                </div>

                <button type="submit" class="button" style="width: 100%; margin-top: 10px;">Send Reset Code</button>
            </form>
            
            <p style="margin-top: 1.5rem; text-align: center;">
                <a href="/login.html" style="color: var(--text-secondary);">Back to Login</a>
            </p>
        </div>
    </main>
    <%- include('partials/footer'); %>
    <script src="/auth.js"></script>
</body>
</html>
