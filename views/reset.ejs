<!DOCTYPE html>
<html lang="en">
<%- include('partials/head'); %>
<body>
    <%- include('partials/header'); %>
    <main>
        <div class="content-box" style="max-width: 400px; margin: 0 auto; text-align: center;">
            <h2>Reset Password</h2>
            <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">
                Check your email for the code. It expires in 1 hour.
            </p>

            <% if (message) { %>
                <div class="message error" style="margin-bottom: 1.5rem;">
                    <%= message %>
                </div>
            <% } %>

            <form action="/reset-password" method="POST">
                <div class="form-group">
                    <label style="text-align: left; display: block;">Email Address</label>
                    <input type="email" name="email" value="<%= email %>" required placeholder="Confirm your email">
                </div>

                <div class="form-group">
                    <label style="text-align: left; display: block;">6-Digit Code</label>
                    <input type="text" name="code" placeholder="123456" required maxlength="6" style="letter-spacing: 2px; font-weight: bold; text-align: center;">
                </div>

                <div class="form-group">
                    <label style="text-align: left; display: block;">New Password</label>
                    <input type="password" name="newPassword" placeholder="Enter new password" required minlength="6">
                </div>

                <button type="submit" class="button" style="width: 100%;">Reset Password</button>
            </form>
        </div>
    </main>
    <%- include('partials/footer'); %>
    <script src="/auth.js"></script>
</body>
</html>
